{
    "manifest_version":  3,
    "name":  "Robust Auto-Resumer",
    "version":  "1.0",
    "description":  "Automatically resumes downloads that are interrupted due to network drops.",
    "permissions":  [
                        "downloads"
                    ],
    "background":  {
                       "service_worker":  "background.js"
                   },
    "action":  {
                   "default_popup":  "popup.html"
               },
    "icons":  {
                  "16":  "icons/icon16.png",
                  "128":  "icons/icon128.png",
                  "48":  "icons/icon48.png"
              }
}
